            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Omar Mostafa\",\n  \"email\": \"omar@example.com\",\n  \"password\": \"A1234\",\n  \"rePassword\": \"A1234\",\n  \"phone\": \"01001234567\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/signup"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) {",
                  "    pm.environment.set('token', json.token);",
                  "  }",
                  "  if (json.user && json.user._id) {",
                  "    pm.environment.set('user_id', json.user._id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
